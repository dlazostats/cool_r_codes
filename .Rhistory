library(httr2)
library(dplyr)
library(lubridate)
# Step 1: Find the event via the Gamma API
event_slug <- "peru-presidential-election-winner"
resp <- request("https://gamma-api.polymarket.com/events") |>
req_url_query(slug = event_slug) |>
req_perform()
event_data <- resp_body_json(resp)
# Step 2: Extract markets
markets <- event_data[[1]]$markets
# Step 3: Capture fetch timestamp in Peru time (UTC-5)
peru_time <- with_tz(Sys.time(), tzone = "America/Lima")
fetch_date <- format(peru_time, "%Y-%m-%d")
fetch_hour <- format(peru_time, "%H:%M:%S")
# Step 4: Parse each market into a data frame
candidates_df <- lapply(markets, function(m) {
data.frame(
candidate   = m$groupItemTitle,
probability = round(as.numeric(m$lastTradePrice) * 100, 1),
volume_usd  = round(as.numeric(m$volume), 0),
date        = fetch_date,
hour_peru   = fetch_hour,
stringsAsFactors = FALSE
)
}) |> bind_rows()
# Step 5: Sort and get top 5
top <- candidates_df |>
arrange(desc(probability)) |>
head(8) %>%
dplyr::select(date,hour_peru,candidate,probability)
top
