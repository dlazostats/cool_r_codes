cat("Test RMSE:", round(rmse_tst, 3), "\n")
imp <- varimp(
model_cforest,
conditional = TRUE   # TRUE = conditional importance (slower but unbiased)
# FALSE = standard permutation importance
)
vimp <- party::varimp(model_cforest, conditional = TRUE)
dotchart(sort(vimp), main = "Conditional Variable Importance")
# or with ggplot
