library(ranger)
set.seed(42)
n <- 500
X1 <- rnorm(n)
X2 <- rnorm(n)
X3 <- rnorm(n)
y  <- 2*X1 - 1.5*X2 + rnorm(n)
df <- data.frame(y, X1, X2, X3)
# ── 1. Variance (default regression splitrule) ────────────────────────────────
rf_variance <- ranger(
y ~ ., data = df,
num.trees  = 500,
splitrule  = "variance",
importance = "impurity"   # uses variance reduction as importance
)
cat("Variance | OOB R²:", rf_variance$r.squared, "\n")
print(rf_variance$variable.importance)
# ── 2. ExtraTrees (random cutpoints) ─────────────────────────────────────────
rf_extra <- ranger(
y ~ ., data = df,
num.trees  = 500,
splitrule  = "extratrees",
num.random.splits = 5,    # how many random cutpoints to try per variable
importance = "impurity"
)
cat("ExtraTrees | OOB R²:", rf_extra$r.squared, "\n")
print(rf_extra$variable.importance)
# ── 3. Maxstat (maximally selected rank statistics) ───────────────────────────
rf_maxstat <- ranger(
y ~ ., data = df,
num.trees  = 500,
splitrule  = "maxstat",
alpha      = 0.05,   # significance level for the rank test
minprop    = 0.1,    # min proportion of obs in each child node
importance = "impurity"
)
cat("Maxstat | OOB R²:", rf_maxstat$r.squared, "\n")
print(rf_maxstat$variable.importance)
# ── Compare OOB errors side by side ──────────────────────────────────────────
results <- data.frame(
splitrule = c("variance", "extratrees", "maxstat"),
OOB_R2    = c(rf_variance$r.squared,
rf_extra$r.squared,
rf_maxstat$r.squared),
OOB_MSE   = c(rf_variance$prediction.error,
rf_extra$prediction.error,
rf_maxstat$prediction.error)
)
print(results)
